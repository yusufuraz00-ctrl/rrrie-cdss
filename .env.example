# ===== LLM Inference — Local (HuggingFace Transformers) =====
HF_MODEL_NAME=Qwen/Qwen3-4B

# ===== LLM Inference — Cloud (Groq, for R2 stage) =====
GROQ_API_KEY=gsk_your-groq-api-key
GROQ_API_URL=https://api.groq.com/openai/v1
CLOUD_MODEL_NAME=llama-3.3-70b-versatile

# ===== Fallback Cloud (if Groq rate-limited) =====
TOGETHER_API_KEY=your-together-api-key
TOGETHER_MODEL_NAME=Qwen/Qwen3-32B

# ===== Medical APIs (NCBI / PubMed) =====
NCBI_EMAIL=your-email@example.com
NCBI_API_KEY=your-ncbi-api-key
TAVILY_API_KEY=your-tavily-api-key

# ===== WHO ICD-11 API (OAuth2) — register at https://icd.who.int/icdapi =====
ICD11_CLIENT_ID=your-client-id
ICD11_CLIENT_SECRET=your-client-secret

# ===== Cache =====
REDIS_URL=redis://localhost:6379/0
CACHE_TTL=3600

# ===== Application =====
LOG_LEVEL=INFO
MAX_RRRIE_ITERATIONS=3
CONFIDENCE_THRESHOLD=0.85
